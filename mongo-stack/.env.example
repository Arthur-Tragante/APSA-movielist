# ===== Mongo compartilhado =====
# Credenciais root (use uma senha forte, sem caracteres @ : / # ? para evitar
# escapar na URI; se usar especiais, faça URL-encode no MONGODB_URI dos apps)
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=troque-essa-senha

# Porta exposta no host. Mude se já tiver outro Mongo rodando.
MONGO_PORT=27017

# ===== Restore (apenas para docker-compose.restore.yml) =====
# Caminho ABSOLUTO no host até a pasta PAI que contém o subdiretório com nome
# da DB (ex.: apsa-movielist/movies.bson). Aponte para mongodump_..._XXXXXX,
# NÃO para mongodump_..._XXXXXX/apsa-movielist.
DUMP_PATH=/caminho/absoluto/para/mongodump_apsa-movielist_20260502_022908

# Nome da DB dentro do dump (pasta dentro do mongodump)
DUMP_DB_NAME=apsa-movielist

# Nome da DB de destino (geralmente igual)
TARGET_DB_NAME=apsa-movielist

# Se "true", apaga as collections existentes antes de restaurar
DROP_BEFORE_RESTORE=false
