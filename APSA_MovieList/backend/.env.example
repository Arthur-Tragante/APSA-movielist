# Server
PORT=3001
NODE_ENV=development

# MongoDB
MONGODB_ENABLED=true
MONGODB_URI=mongodb://localhost:27017/apsa-movielist

# JWT — use a strong random value in production (e.g. openssl rand -hex 32)
JWT_SECRET=replace-with-a-strong-random-secret

# External APIs
TMDB_API_KEY=your_tmdb_bearer_token
OMDB_API_KEY=your_omdb_api_key

# Redis (optional — falls back to in-memory cache if disabled)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_ENABLED=false

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS — set to your frontend URL
CORS_ORIGIN=http://localhost:5173

# Cache TTL in seconds
CACHE_TTL_TMDB=86400
CACHE_TTL_OMDB=86400
