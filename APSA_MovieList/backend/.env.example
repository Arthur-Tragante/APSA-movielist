# Servidor
PORT=3001
NODE_ENV=development

# MongoDB
MONGODB_ENABLED=true
MONGODB_URI=mongodb://localhost:27017/apsa-movielist

# JWT (troque o secret em produção!)
JWT_SECRET=apsa-movielist-troque-este-secret

# APIs Externas
TMDB_API_KEY=your_tmdb_api_key_here
OMDB_API_KEY=your_omdb_api_key_here

# Redis (opcional)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_ENABLED=false

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:5173

# Cache TTL (em segundos)
CACHE_TTL_TMDB=86400
CACHE_TTL_OMDB=86400

# Firebase (apenas para exportação de dados - não necessário em produção)
# FIREBASE_PROJECT_ID=apsa-movielist
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@apsa-movielist.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# FIREBASE_DATABASE_URL=https://apsa-movielist-default-rtdb.firebaseio.com
