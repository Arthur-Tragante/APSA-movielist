# ===== Conexão com Mongo compartilhado =====
# Devem ser os MESMOS valores configurados no stack mongo-stack
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=troque-essa-senha
MONGO_DB_NAME=apsa-movielist

# ===== Portas expostas no host =====
BACKEND_PORT=3001
FRONTEND_PORT=8080

# ===== Backend - Segurança =====
# Gere com: openssl rand -hex 32
JWT_SECRET=replace-with-a-strong-random-secret

# ===== Backend - APIs externas =====
TMDB_API_KEY=your_tmdb_bearer_token
OMDB_API_KEY=your_omdb_api_key

# ===== Backend - URLs =====
# CORS_ORIGIN deve ser a URL pública do frontend
CORS_ORIGIN=http://localhost:8080
FRONTEND_URL=http://localhost:8080

# ===== Backend - SMTP (opcional, deixe vazio se não usar e-mail) =====
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# ===== Frontend (build-time, embutido no bundle) =====
VITE_API_URL=http://localhost:3001/api
VITE_DISCORD_WEBHOOK_URL=
